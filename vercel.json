{
  "version": 2,
  "buildCommand": "cd ecommerce-web && npm install && npm run build",
  "outputDirectory": "ecommerce-web/dist",
  "env": {
    "VITE_API_BASE_URL": "/api/v1"
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
